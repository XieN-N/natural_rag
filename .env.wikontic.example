# ── Wikontic Pipeline Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values.
#
# Fallback chain for API key: WIKONTIC_API_KEY → OPENAI_API_KEY → KEY → OPENROUTER_KEY
# Fallback chain for base URL: WIKONTIC_BASE_URL → OPENAI_BASE_URL → OPENROUTER_BASE_URL
# Fallback chain for model:    WIKONTIC_MODEL → LLM_MODEL → "gpt-4o"

# LLM Provider (can also use OPENAI_API_KEY / OPENAI_BASE_URL)
WIKONTIC_API_KEY=sk-your-api-key-here
WIKONTIC_BASE_URL=https://api.openai.com/v1
WIKONTIC_MODEL=gpt-4o

# Pipeline mode: "structured" (Wikidata ontology) or "dynamic" (no ontology)
WIKONTIC_MODE=structured

# Storage backend: "qdrant" or "mongo"
WIKONTIC_STORAGE_BACKEND=qdrant
WIKONTIC_QDRANT_URL=:memory:
# WIKONTIC_QDRANT_API_KEY=  # for Qdrant Cloud
# WIKONTIC_MONGO_URI=mongodb://localhost:27018/

# Database names
WIKONTIC_ONTOLOGY_DB_NAME=wikidata_ontology
WIKONTIC_TRIPLETS_DB_NAME=triplets_db

# Language
WIKONTIC_LANGUAGE=en

# Device override (auto-detected by default: cuda if available, else cpu)
# WIKONTIC_DEVICE=cpu

# HTTP proxy for LLM API calls (optional)
# WIKONTIC_PROXY_URL=http://proxy.example.com:8080

# Log level
WIKONTIC_LOG_LEVEL=INFO
